# Database (Supabase)
# Transaction Mode Pooler (port 6543) — dùng cho app queries
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true&connection_limit=1"

# Direct connection (port 5432) — dùng cho migrations (prisma migrate)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Auth.js / NextAuth
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
